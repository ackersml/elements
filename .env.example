# Production site URL (no trailing slash) — used for metadata, sitemap, Stripe success URLs
NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app

# Optional: short looped audio for hero (leave unset to hide the gate copy)
# NEXT_PUBLIC_HERO_AUDIO_URL=

# Stripe (server)
STRIPE_SECRET_KEY=sk_live_or_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Supabase (server — orders + webhooks)
# Vercel ↔ Supabase integration usually sets NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY.
# Manual setup can use SUPABASE_URL instead of NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Fulfillment stub (optional)
# FULFILLMENT_MODE=manual
